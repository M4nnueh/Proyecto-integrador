{
  "realm": "curso-springboot",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "angular-client",
      "name": "angular-client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "administrador",
        "description": "Administrador: acceso total"
      },
      {
        "name": "estudiante",
        "description": "Estudiante: acceso a cursos"
      },
      {
        "name": "profesor",
        "description": "Profesor: imparte cursos"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["administrador"]
    },
    {
      "username": "estudiante1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Juan",
      "lastName": "Perez",
      "email": "juan@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "juan123",
          "temporary": false
        }
      ],
      "realmRoles": ["estudiante"]
    },
    {
      "username": "profesor1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Maria",
      "lastName": "Gomez",
      "email": "maria@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "maria123",
          "temporary": false
        }
      ],
      "realmRoles": ["profesor"]
    }
  ]
}
