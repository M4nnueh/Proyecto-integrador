{
  "realm": "curso-springboot",
  "enabled": true,
  "sslRequired": "none",
  "defaultRole": {
    "name": "default-roles-curso-springboot"
  },
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "angular-client",
      "name": "angular-client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "administrador",
        "description": "Administrador: acceso total"
      },
      {
        "name": "estudiante",
        "description": "Estudiante: acceso a cursos"
      },
      {
        "name": "profesor",
        "description": "Profesor: imparte cursos"
      },
      {
        "name": "default-roles-curso-springboot",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["estudiante", "offline_access"]
        }
      }
    ]
  },
